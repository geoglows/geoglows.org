---
interface Props {
  text: string;
  url: string;
  date: Date;
  author?: string;
  image?: string;
}
const { text, url, date, author = "GEOGLOWS", image } = Astro.props;
const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="post">
  <header class="head">
    <span class="mark" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path
          d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"
        ></path>
      </svg>
    </span>
    <span class="who">
      <span class="name">{author}</span>
      <time class="date" datetime={date.toISOString()}>{formatted}</time>
    </span>
  </header>
  <p class="text">{text}</p>
  {image && <img class="media" src={image} alt="" loading="lazy" />}
  <a class="view" href={url} target="_blank" rel="noopener">View post →</a>
</article>

<style>
  .post {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
  }
  .head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .mark {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: #0a66c2;
    color: #fff;
    flex-shrink: 0;
  }
  .who {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .name {
    font-weight: 700;
    color: var(--text-strong);
    font-size: 0.92rem;
  }
  .date {
    color: var(--text-faint);
    font-size: 0.78rem;
  }
  .text {
    color: var(--text-body);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .media {
    width: 100%;
    border-radius: 10px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .view {
    margin-top: auto;
    color: var(--accent-text);
    font-weight: 700;
    font-size: 0.88rem;
    text-decoration: none;
  }
  .view:hover {
    text-decoration: underline;
  }
</style>
