---
interface Props {
  url: string;
  text?: string;
}
const { url, text } = Astro.props;
const activityId = url.match(/activity[-:](\d+)/)?.[1];
const embed = activityId
  ? `https://www.linkedin.com/embed/feed/update/urn:li:activity:${activityId}`
  : null;
---

{
  embed ? (
    <article class="post">
      <div class="viewport">
        <iframe
          class="li-frame"
          src={embed}
          title={text ?? "LinkedIn post"}
          loading="lazy"
          frameborder="0"
          allowfullscreen
        />
        <div class="fade" aria-hidden="true" />
      </div>
      <a class="foot" href={url} target="_blank" rel="noopener">
        <svg class="glyph" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z" />
        </svg>
        Read on LinkedIn
        <span class="arrow" aria-hidden="true">→</span>
      </a>
    </article>
  ) : (
    <a class="fallback" href={url} target="_blank" rel="noopener">
      Read on LinkedIn →
    </a>
  )
}

<style>
  .post {
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid var(--hairline-on-dark, rgba(255, 255, 255, 0.14));
    box-shadow: 0 10px 30px rgba(8, 24, 38, 0.16);
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.25s ease;
  }
  .post:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 44px rgba(8, 24, 38, 0.24);
  }
  @media (prefers-reduced-motion: reduce) {
    .post {
      transition: none;
    }
    .post:hover {
      transform: none;
    }
  }

  .viewport {
    position: relative;
    height: 430px;
    overflow: hidden;
    background: #eef1f4;
  }
  /* The embed is a cross-origin iframe: size it taller than the viewport and
     wider than the frame so its own scrollbar is clipped out of sight. */
  .li-frame {
    display: block;
    width: calc(100% + 18px);
    height: 720px;
    border: 0;
    background: #ffffff;
  }
  .fade {
    position: absolute;
    inset: auto 0 0;
    height: 72px;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0), #ffffff);
    pointer-events: none;
  }

  .foot {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 52px;
    padding: 0 20px;
    background: #ffffff;
    border-top: 1px solid rgba(10, 22, 34, 0.08);
    color: #0a66c2;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
  }
  .glyph {
    flex-shrink: 0;
  }
  .arrow {
    margin-left: auto;
    transition: transform 0.2s ease;
  }
  .foot:hover .arrow {
    transform: translateX(4px);
  }
  @media (prefers-reduced-motion: reduce) {
    .arrow {
      transition: none;
    }
  }

  .fallback {
    display: grid;
    place-items: center;
    min-height: 120px;
    padding: 20px;
    border-radius: 16px;
    background: #ffffff;
    color: #0a66c2;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(8, 24, 38, 0.16);
  }
</style>
