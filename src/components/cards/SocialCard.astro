---
interface Props {
  url: string;
  text?: string;
}
const { url, text } = Astro.props;
const activityId = url.match(/activity[-:](\d+)/)?.[1];
const embed = activityId
  ? `https://www.linkedin.com/embed/feed/update/urn:li:activity:${activityId}`
  : null;
---

{
  embed ? (
    <iframe
      class="li-card"
      src={embed}
      title={text ?? "LinkedIn post"}
      loading="lazy"
      frameborder="0"
      allowfullscreen
    />
  ) : (
    <a class="fallback" href={url} target="_blank" rel="noopener">
      View post on LinkedIn →
    </a>
  )
}

<style>
  .li-card {
    width: 100%;
    height: 560px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
  }
  .fallback {
    display: grid;
    place-items: center;
    min-height: 120px;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface-page);
    color: var(--accent-text);
    font-weight: 700;
    text-decoration: none;
  }
</style>
