---
import { marked } from "marked";

interface Props {
  name: string;
  title?: string;
  organization?: string;
  country?: string;
  photo?: string;
  initials: string;
  bio?: string;
}
const { name, title, organization, country, photo, initials, bio } = Astro.props;
const affiliation = [organization, country].filter(Boolean).join(" · ");
const bioHtml = bio?.trim() ? marked.parse(bio) : "";
---

<article class="person">
  <div class="head">
    {
      photo ? (
        <img class="photo" src={photo} alt={name} width="56" height="56" loading="lazy" decoding="async" />
      ) : (
        <span class="avatar">{initials}</span>
      )
    }
    <div class="info">
      <h3>{name}</h3>
      {title && <p class="title">{title}</p>}
      {affiliation && <p class="affiliation">{affiliation}</p>}
    </div>
  </div>
  {
    bioHtml && (
      <details class="bio">
        <summary>Read bio</summary>
        <div class="bio-body" set:html={bioHtml} />
      </details>
    )
  }
</article>

<style>
  .person {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
  }
  .head {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .photo,
  .avatar {
    flex: none;
    width: 56px;
    height: 56px;
    border-radius: 50%;
  }
  .photo {
    object-fit: cover;
  }
  .avatar {
    display: grid;
    place-items: center;
    background: radial-gradient(circle at 30% 30%, #3a5a7a, #243754);
    color: #fff;
    font-weight: 800;
    font-size: 0.95rem;
  }
  h3 {
    font-size: 1rem;
  }
  .title {
    margin-top: 2px;
    color: var(--text-body);
    font-size: 0.85rem;
  }
  .affiliation {
    color: var(--text-faint);
    font-size: 0.8rem;
  }
  .bio {
    margin-top: 14px;
  }
  .bio summary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    list-style: none;
    cursor: pointer;
    color: var(--accent-text);
    font-size: 0.82rem;
    font-weight: 700;
  }
  .bio summary::-webkit-details-marker {
    display: none;
  }
  .bio summary::after {
    content: "↓";
    font-size: 0.75rem;
    transition: transform 0.2s ease;
  }
  .bio[open] summary::after {
    transform: rotate(180deg);
  }
  .bio-body {
    margin-top: 8px;
    color: var(--text-body);
    font-size: 0.88rem;
    line-height: 1.55;
  }
  .bio-body :global(p) {
    margin: 0;
  }
  .bio summary:focus-visible {
    outline: 2px solid var(--cta);
    outline-offset: 3px;
    border-radius: 4px;
  }
</style>
