---
interface Props {
  title: string;
  authors: string[];
  year: number;
  journal?: string;
  doi?: string;
  url?: string;
  topics: string[];
  image?: string;
}
const { title, authors, year, journal, doi, url, topics, image } = Astro.props;
const searchText = [title, authors.join(" "), journal, ...topics]
  .filter(Boolean)
  .join(" ")
  .toLowerCase();
const href = url ?? (doi ? `https://doi.org/${doi}` : undefined);
---

<article
  class="pub"
  data-search={searchText}
  data-topics={topics.join("|")}
  data-year={year}
>
  {
    image && (
      <div class="cover" style={`background-image:url(${image})`}>
        <span class="year">{year}</span>
      </div>
    )
  }
  <div class="body">
    <div class="tags">
      {!image && <span class="year year-inline">{year}</span>}
      {topics.map((topic) => <span class="topic">{topic}</span>)}
    </div>
    <h3>{href ? <a href={href}>{title}</a> : title}</h3>
    <p class="authors">{authors.join("; ")}</p>
    {journal && <p class="journal">{journal}</p>}
    {doi && <span class="doi">doi:{doi}</span>}
  </div>
</article>

<style>
  .pub {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .pub:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  @media (prefers-reduced-motion: reduce) {
    .pub:hover {
      transform: none;
    }
  }
  .cover {
    position: relative;
    height: 128px;
    background-size: cover;
    background-position: center;
  }
  .cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8, 28, 42, 0.05), rgba(8, 28, 42, 0.45));
  }
  .cover .year {
    position: absolute;
    left: 14px;
    bottom: 12px;
    z-index: 1;
    color: #fff;
    font-family: "Raleway", sans-serif;
    font-weight: 800;
    font-size: 1.25rem;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 1px 6px rgba(8, 28, 42, 0.5);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    padding: 18px 20px 20px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }
  .year-inline {
    color: var(--accent-text);
    font-family: "Raleway", sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    font-variant-numeric: tabular-nums;
    margin-right: 4px;
  }
  .topic {
    padding: 2px 9px;
    border-radius: 4px;
    background: var(--surface-wash);
    color: var(--accent-text);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  h3 {
    font-size: 1.02rem;
    line-height: 1.3;
  }
  h3 a {
    color: var(--text-strong);
    text-decoration: none;
  }
  h3 a:hover {
    color: var(--accent-text);
  }
  .authors {
    color: var(--text-body);
    font-size: 0.85rem;
  }
  .journal {
    color: var(--text-body);
    font-size: 0.85rem;
    font-style: italic;
  }
  .doi {
    margin-top: auto;
    padding-top: 8px;
    color: var(--text-faint);
    font-size: 0.73rem;
    font-family: ui-monospace, Menlo, Consolas, monospace;
    overflow-wrap: anywhere;
  }
</style>
