---
import { bgImage } from "../../lib/css";

interface Props {
  title: string;
  date: string;
  youtubeId: string;
  presenter: string;
  description: string;
}
const { title, date, youtubeId, presenter, description } = Astro.props;
const href = `https://www.youtube.com/watch?v=${youtubeId}`;
const thumb = `https://img.youtube.com/vi/${youtubeId}/hqdefault.jpg`;
---

<article class="webinar">
  <a class="thumb" href={href} target="_blank" rel="noopener" style={bgImage(thumb)} aria-label={`Watch: ${title}`}>
    <span class="play" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
    </span>
  </a>
  <div class="body">
    <p class="meta">{date} · {presenter}</p>
    <h3>{title}</h3>
    <p class="desc">{description}</p>
    <a class="watch" href={href} target="_blank" rel="noopener">Watch webinar →</a>
  </div>
</article>

<style>
  .webinar {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
  }
  .thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    display: block;
  }
  .play {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(8, 28, 42, 0.72);
    color: #fff;
    transition: background 0.16s ease;
  }
  .thumb:hover .play {
    background: var(--color-teal-green);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 7px;
    flex: 1;
    padding: 16px 18px 16px;
  }
  .meta {
    color: var(--accent-text);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  h3 {
    font-size: 1.05rem;
    line-height: 1.3;
  }
  .desc {
    flex: 1;
    color: var(--text-body);
    font-size: 0.86rem;
    line-height: 1.5;
  }
  .watch {
    color: var(--accent-text);
    font-size: 0.82rem;
    font-weight: 800;
    text-decoration: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .play {
      transition: none;
    }
  }
</style>
