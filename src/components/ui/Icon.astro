---
import { icons } from "../../lib/icons";

interface Props {
  name: string;
  size?: number;
}
const { name, size = 24 } = Astro.props;
const markup = icons[name] ?? icons.globe;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={markup}
/>
