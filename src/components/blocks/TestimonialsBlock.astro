---
import type { Block } from "../../schemas/blocks";
const { quotes } = Astro.props as Extract<Block, { type: "testimonials" }>;
---

<section class="block">
  <div class="shell grid">
    {
      quotes.map((q) => (
        <figure class="quote">
          <div class="mark">&ldquo;</div>
          <p>{q.quote}</p>
          <figcaption>
            <span class="avatar">{q.initials}</span>
            <span>
              <b>{q.name}</b>
              <span class="role">{q.role}</span>
            </span>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px;
  }
  .quote {
    margin: 0;
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
  }
  .mark {
    font-family: Georgia, serif;
    font-size: 3rem;
    line-height: 0.5;
    color: var(--color-amber);
  }
  .quote p {
    margin: 10px 0 18px;
    color: var(--text-strong);
    font-size: 1.05rem;
  }
  figcaption {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .avatar {
    display: grid;
    place-items: center;
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #3a5a7a, #243754);
    color: #fff;
    font-weight: 800;
    font-size: 0.85rem;
  }
  figcaption b {
    display: block;
    color: var(--text-strong);
    font-size: 0.92rem;
  }
  .role {
    color: var(--text-faint);
    font-size: 0.82rem;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
