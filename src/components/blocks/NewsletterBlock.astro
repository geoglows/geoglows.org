---
import type { Block } from "../../schemas/blocks";
const { heading, text, buttonLabel } = Astro.props as Extract<
  Block,
  { type: "newsletter" }
>;
---

<section class="block">
  <div class="shell">
    <div class="panel">
      <h2>{heading}</h2>
      {text && <p>{text}</p>}
      <form class="form" method="post" action="#">
        <input type="text" name="firstName" placeholder="First name" aria-label="First name" required />
        <input type="email" name="email" placeholder="Email address" aria-label="Email" required />
        <button type="submit">{buttonLabel}</button>
      </form>
    </div>
  </div>
</section>

<style>
  .panel {
    position: relative;
    overflow: hidden;
    padding: 48px 40px;
    border-radius: 20px;
    background: linear-gradient(150deg, #0060a9, #17707a 60%, #008b7b);
    color: #eef7f8;
    text-align: center;
  }
  .panel::before,
  .panel::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.14);
  }
  .panel::before {
    width: 260px;
    height: 260px;
    top: -90px;
    right: -40px;
  }
  .panel::after {
    width: 200px;
    height: 200px;
    top: -60px;
    right: 60px;
  }
  h2 {
    position: relative;
    color: #fff;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
  }
  p {
    position: relative;
    max-width: 52ch;
    margin: 12px auto 0;
    color: #c3d1e2;
  }
  .form {
    position: relative;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 26px;
  }
  input {
    min-width: 220px;
    padding: 13px 16px;
    border: none;
    border-radius: 9px;
    font: inherit;
  }
  button {
    padding: 13px 26px;
    border: none;
    border-radius: 9px;
    background: var(--cta);
    color: var(--cta-ink);
    font-weight: 800;
    cursor: pointer;
    transition: filter 0.16s ease;
  }
  button:hover {
    filter: brightness(1.06);
  }
  button:active {
    filter: brightness(0.96);
  }
</style>
