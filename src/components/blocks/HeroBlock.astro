---
import { getEntry } from "astro:content";
import type { Block } from "../../schemas/blocks";
import CtaButton from "../ui/CtaButton.astro";
import GeoGlyph from "../site/GeoGlyph.astro";
import EventsTicker from "../site/EventsTicker.astro";

type Hero = Extract<Block, { type: "hero" }>;
const { eyebrow, headingLead, headingEmphasis, subtitle, image, ctas, featured } =
  Astro.props as Hero;

const discs = [
  { src: "/images/aerial-satellite.webp", cap: "Satellite view", cls: "d1" },
  { src: "/images/aerial-river.webp", cap: "River network", cls: "d2" },
  { src: "/images/aerial-basin.webp", cap: "Basin", cls: "d3" },
];
const ticker = (await getEntry("settings", "site"))!.data.ticker;
---

<header class="hero">
  {
    image && (
      <img
        class="hero-photo"
        src={image}
        alt=""
        width="1600"
        height="840"
        fetchpriority="high"
        decoding="async"
      />
    )
  }
  <div class="hero-circles" aria-hidden="true">
    {
      discs.map((d) => (
        <div class:list={["disc", d.cls]} style={`background-image:url(${d.src})`}>
          <span class="cap">{d.cap}</span>
        </div>
      ))
    }
  </div>
  <div class="shell hero-inner">
    {
      eyebrow && (
        <p class="hero-eyebrow">
          <GeoGlyph left="#8fd8ee" right="#ffbf00" />
          {eyebrow}
        </p>
      )
    }
    <h1>{headingLead} {headingEmphasis && <em>{headingEmphasis}</em>}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    <div class="ctas">
      {ctas.map((cta) => <CtaButton href={cta.href} label={cta.label} style={cta.style} />)}
    </div>
  </div>
  {
    featured && (
      <aside class="hero-card">
        <span class="tag">{featured.tag}</span>
        <h3>{featured.title}</h3>
        <p>{featured.text}</p>
        <a href={featured.href}>Explore →</a>
      </aside>
    )
  }
  <EventsTicker items={ticker} />
</header>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #0b2a3f;
    color: #eef7f8;
  }
  .hero-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      90deg,
      rgba(8, 28, 42, 0.86) 0%,
      rgba(8, 28, 42, 0.6) 44%,
      rgba(8, 28, 42, 0.12) 100%
    );
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    padding: 92px 28px 96px;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    color: #bfe4ea;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  h1 {
    max-width: 15ch;
    color: #f4fbfc;
    font-size: clamp(2.4rem, 5.4vw, 4.2rem);
    letter-spacing: -0.02em;
    line-height: 1.06;
  }
  h1 em {
    font-style: normal;
    color: var(--color-amber);
  }
  .subtitle {
    max-width: 54ch;
    margin: 24px 0 34px;
    color: #d3e6ea;
    font-size: 1.13rem;
    line-height: 1.65;
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .hero-circles {
    position: absolute;
    right: calc((100vw - var(--page-max)) / 2 + 24px);
    top: 44%;
    transform: translateY(-50%);
    z-index: 2;
    display: none;
    pointer-events: none;
  }
  .disc {
    position: absolute;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.92);
    background-size: cover;
    background-position: center;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
  }
  .d1 {
    width: 250px;
    height: 250px;
    right: 120px;
    top: -170px;
  }
  .d2 {
    width: 180px;
    height: 180px;
    right: -10px;
    top: 30px;
  }
  .d3 {
    width: 120px;
    height: 120px;
    right: 200px;
    top: 90px;
  }
  .cap {
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    padding: 2px 9px;
    border-radius: 20px;
    background: rgba(8, 28, 42, 0.55);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .hero-card {
    display: none;
  }
  /* The card is always a light overlay on the photo, so use fixed dark text
     (theme tokens would flip to light in dark mode and wash out on white). */
  .hero-card .tag {
    color: #0a6157;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .hero-card h3 {
    margin: 6px 0 8px;
    color: #16202e;
    font-size: 1.1rem;
  }
  .hero-card p {
    margin-bottom: 14px;
    color: #45525f;
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .hero-card a {
    display: inline-block;
    padding: 9px 16px;
    border-radius: 8px;
    background: var(--color-navy);
    color: #fff;
    font-size: 0.76rem;
    font-weight: 800;
    text-decoration: none;
  }
  @media (min-width: 1120px) {
    .hero-circles {
      display: block;
    }
    .hero-card {
      display: block;
      position: absolute;
      right: calc((100vw - var(--page-max)) / 2 + 24px);
      bottom: 118px;
      z-index: 3;
      width: 290px;
      padding: 20px;
      border-radius: 14px;
      background: #ffffff;
      color: #45525f;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
    }
  }
</style>
