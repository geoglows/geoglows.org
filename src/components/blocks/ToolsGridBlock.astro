---
import { getCollection } from "astro:content";
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import ToolCard from "../cards/ToolCard.astro";

const { eyebrow, heading, intro, category, limit, cta } = Astro.props as Extract<
  Block,
  { type: "toolsGrid" }
>;

const sorted = (await getCollection("tools"))
  .filter((tool) => !category || tool.data.category === category)
  .sort((a, b) => a.data.order - b.data.order);
const tools = limit ? sorted.slice(0, limit) : sorted;
---

<section class="block">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} intro={intro} />
    <div class="grid">
      {
        tools.map((tool) => (
          <ToolCard
            name={tool.data.name}
            tagline={tool.data.tagline}
            category={tool.data.category}
            icon={tool.data.icon}
            href={`/tools/${tool.id}`}
          />
        ))
      }
    </div>
    {
      cta && (
        <div class="center">
          <a class="all" href={cta.href}>
            {cta.label} →
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .center {
    margin-top: 32px;
    text-align: center;
  }
  .all {
    color: var(--accent-text);
    font-weight: 800;
    text-decoration: none;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
