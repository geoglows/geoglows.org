---
import { getCollection } from "astro:content";
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import ToolCard from "../cards/ToolCard.astro";

const { eyebrow, heading, intro, category } = Astro.props as Extract<
  Block,
  { type: "toolsGrid" }
>;

const tools = (await getCollection("tools"))
  .filter((tool) => !category || tool.data.category === category)
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="block">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} intro={intro} />
    <div class="grid">
      {
        tools.map((tool) => (
          <ToolCard
            name={tool.data.name}
            tagline={tool.data.tagline}
            category={tool.data.category}
            icon={tool.data.icon}
            href={`/tools/${tool.id}`}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
