---
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";

const { eyebrow, heading, intro, items, cta } = Astro.props as Extract<
  Block,
  { type: "coverage" }
>;
---

<section class="block coverage">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} intro={intro} />
    <div class="grid">
      {
        items.map((item) => (
          <div class="cell">
            <div class="ring" style={`background-image:url(${item.image})`} />
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))
      }
    </div>
    {
      cta && (
        <div class="center">
          <a class="all" href={cta.href}>
            {cta.label} →
          </a>
        </div>
      )
    }
  </div>
</section>

<style>
  .coverage {
    background: var(--surface-wash);
  }
  .center {
    margin-top: 32px;
    text-align: center;
  }
  .all {
    color: var(--accent-text);
    font-weight: 800;
    text-decoration: none;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 26px;
  }
  .cell {
    text-align: center;
  }
  .ring {
    width: 100%;
    max-width: 190px;
    aspect-ratio: 1;
    margin: 0 auto 16px;
    border-radius: 50%;
    border: 4px solid #fff;
    background-size: cover;
    background-position: center;
    box-shadow: var(--shadow-md);
  }
  h3 {
    font-size: 1.02rem;
  }
  p {
    margin-top: 6px;
    color: var(--text-body);
    font-size: 0.86rem;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }
  }
</style>
