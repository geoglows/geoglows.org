---
import type { Block } from "../../schemas/blocks";
const { stats } = Astro.props as Extract<Block, { type: "statBand" }>;
const [lead, ...rest] = stats;
---

<div class="stat-band">
  <div class="shell inner">
    <div class="lead">
      <span class="lead-value">{lead.value}</span>
      <span class="lead-label">{lead.label}</span>
    </div>
    <div class="rest">
      {
        rest.map((stat) => (
          <div class="stat">
            <span class="value">{stat.value}</span>
            <span class="label">{stat.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .stat-band {
    position: relative;
    overflow: hidden;
    background: var(--color-navy-deep);
    color: #dfe7f0;
  }
  /* overlapping-circles brand motif, oversized and bled off the edge */
  .stat-band::after {
    content: "";
    position: absolute;
    top: -40%;
    right: -60px;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    border: 1px solid rgba(113, 172, 178, 0.25);
    box-shadow: 90px 0 0 -1px rgba(0, 96, 169, 0.18);
    pointer-events: none;
  }
  .inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.3fr);
    align-items: center;
    gap: clamp(28px, 6vw, 80px);
    padding-block: clamp(40px, 6vw, 72px);
  }
  .lead-value {
    display: block;
    color: #fff;
    font-family: "Raleway", sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .lead-label {
    display: block;
    margin-top: 12px;
    max-width: 22ch;
    color: var(--color-teal);
    font-size: 1.05rem;
    font-weight: 600;
  }
  .rest {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 40px);
    border-left: 1px solid rgba(223, 231, 240, 0.14);
    padding-left: clamp(24px, 4vw, 56px);
  }
  .value {
    display: block;
    color: #fff;
    font-family: "Raleway", sans-serif;
    font-weight: 800;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .label {
    display: block;
    margin-top: 8px;
    color: #9fb0c6;
    font-size: 0.82rem;
  }
  @media (max-width: 860px) {
    .inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .rest {
      border-left: none;
      padding-left: 0;
    }
  }
  @media (max-width: 520px) {
    .rest {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
</style>
