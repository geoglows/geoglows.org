---
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import CtaButton from "../ui/CtaButton.astro";

const { eyebrow, heading, items, cta } = Astro.props as Extract<
  Block,
  { type: "valueProps" }
>;
---

<section class="block muted">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} align="left" />
    <div class="grid">
      {
        items.map((item) => (
          <div class="value">
            <span class="rule" />
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))
      }
    </div>
    {cta && <div class="cta-row"><CtaButton href={cta.href} label={cta.label} style="green" /></div>}
  </div>
</section>

<style>
  .muted {
    background: var(--surface-muted);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 56px);
  }
  .rule {
    display: block;
    width: 48px;
    height: 4px;
    margin-bottom: 20px;
    background: var(--color-teal-green);
    border-radius: 2px;
  }
  h3 {
    font-size: clamp(1.2rem, 1.8vw, 1.5rem);
    line-height: 1.15;
  }
  p {
    margin-top: 10px;
    max-width: 40ch;
    color: var(--text-body);
    font-size: 0.98rem;
  }
  .cta-row {
    margin-top: 44px;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
