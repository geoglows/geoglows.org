---
import type { CollectionEntry } from "astro:content";
import SocialCard from "../cards/SocialCard.astro";

interface Props {
  posts: CollectionEntry<"social">[];
}
const { posts } = Astro.props;
---

<div class="social-grid">
  {posts.map((post) => <SocialCard {...post.data} />)}
</div>

<dialog class="preview-dialog" aria-label="LinkedIn post preview">
  <button class="close" type="button" aria-label="Close preview">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
    </svg>
  </button>
  <div class="frame-wrap">
    <iframe class="li-embed" title="LinkedIn post preview" frameborder="0" allowfullscreen></iframe>
  </div>
</dialog>

<script>
  const dialog = document.querySelector<HTMLDialogElement>(".preview-dialog");
  const frame = dialog?.querySelector<HTMLIFrameElement>(".li-embed");
  const close = dialog?.querySelector<HTMLButtonElement>(".close");

  document.querySelectorAll<HTMLButtonElement>(".post .preview").forEach((btn) => {
    btn.addEventListener("click", () => {
      if (!dialog || !frame) return;
      frame.src = btn.dataset.embed ?? "";
      dialog.showModal();
    });
  });

  close?.addEventListener("click", () => dialog?.close());
  dialog?.addEventListener("click", (event) => {
    if (event.target === dialog) dialog.close();
  });
  dialog?.addEventListener("close", () => {
    if (frame) frame.src = "about:blank";
  });
</script>

<style>
  .social-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
  }
  @media (max-width: 820px) {
    .social-grid {
      grid-template-columns: 1fr;
    }
  }

  .preview-dialog {
    width: min(92vw, 580px);
    max-height: 90vh;
    padding: 0;
    border: none;
    border-radius: 16px;
    background: var(--surface-page);
    box-shadow: var(--shadow-lg, 0 24px 60px rgba(8, 28, 42, 0.32));
    overflow: visible;
  }
  .preview-dialog::backdrop {
    background: rgba(8, 20, 30, 0.55);
  }
  .close {
    position: absolute;
    top: -14px;
    right: -14px;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 50%;
    background: var(--surface-page);
    color: var(--text-strong);
    box-shadow: var(--shadow-md);
    cursor: pointer;
  }
  .close:hover {
    color: #0a66c2;
  }
  .frame-wrap {
    padding: 14px;
    max-height: 90vh;
    overflow-y: auto;
  }
  .li-embed {
    width: 100%;
    height: 600px;
    border-radius: 10px;
    display: block;
  }
</style>
