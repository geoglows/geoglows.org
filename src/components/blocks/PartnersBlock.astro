---
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import CtaButton from "../ui/CtaButton.astro";

const { eyebrow, heading, logos, cta } = Astro.props as Extract<
  Block,
  { type: "partners" }
>;
---

<section class="block">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} />
    <ul class="grid">
      {
        logos.map((partner) => {
          const inner = partner.image ? (
            <img src={partner.image} alt={partner.name} loading="lazy" decoding="async" />
          ) : (
            <span class="wordmark">{partner.name}</span>
          );
          return (
            <li class="cell">
              {partner.url ? (
                <a href={partner.url} target="_blank" rel="noopener" aria-label={partner.name}>
                  {inner}
                </a>
              ) : (
                inner
              )}
            </li>
          );
        })
      }
    </ul>
    {cta && <div class="center"><CtaButton href={cta.href} label={cta.label} style="navy" /></div>}
  </div>
</section>

<style>
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .cell {
    display: grid;
    place-items: center;
    min-height: 104px;
    padding: 20px 24px;
    border: 1px solid rgba(29, 29, 36, 0.08);
    border-radius: 12px;
    background: #ffffff;
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .cell:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  @media (prefers-reduced-motion: reduce) {
    .cell {
      transition: none;
    }
    .cell:hover {
      transform: none;
    }
  }
  .cell a {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
  }
  .cell img {
    max-height: 50px;
    max-width: 100%;
    width: auto;
    object-fit: contain;
  }
  .wordmark {
    color: var(--color-navy);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    text-align: center;
  }
  .center {
    margin-top: 40px;
    text-align: center;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 520px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
