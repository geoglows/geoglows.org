---
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import CtaButton from "../ui/CtaButton.astro";

const { eyebrow, heading, logos, cta } = Astro.props as Extract<
  Block,
  { type: "partners" }
>;
---

<section class="block">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} />
    <ul class="grid">
      {
        logos.map((partner) => {
          const inner = partner.image ? (
            <img src={partner.image} alt={partner.name} loading="lazy" decoding="async" />
          ) : (
            <span class="wordmark">{partner.name}</span>
          );
          return (
            <li class="cell">
              {partner.url ? (
                <a href={partner.url} target="_blank" rel="noopener" aria-label={partner.name}>
                  {inner}
                </a>
              ) : (
                inner
              )}
            </li>
          );
        })
      }
    </ul>
    {cta && <div class="center"><CtaButton href={cta.href} label={cta.label} style="navy" /></div>}
  </div>
</section>

<style>
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .cell {
    display: grid;
    place-items: center;
    min-height: 96px;
    padding: 18px 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface-page);
  }
  .cell a {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
  }
  .cell img {
    max-height: 52px;
    max-width: 100%;
    width: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.72;
    transition: filter 0.18s ease, opacity 0.18s ease;
  }
  .cell:hover img {
    filter: grayscale(0);
    opacity: 1;
  }
  .wordmark {
    color: var(--text-faint);
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    text-align: center;
  }
  .center {
    margin-top: 40px;
    text-align: center;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 520px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
