---
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import CtaButton from "../ui/CtaButton.astro";

const { eyebrow, heading, intro, stories, cta } = Astro.props as Extract<
  Block,
  { type: "impactStories" }
>;
---

<section class="block">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} intro={intro} />
    <div class="grid">
      {
        stories.map((story) => (
          <a class="story" href={story.href}>
            <div class="cover" style={`background-image:url(${story.image})`}>
              <span class="location">{story.location}</span>
            </div>
            <div class="body">
              <h3>{story.title}</h3>
              <span class="more">Read the story →</span>
            </div>
          </a>
        ))
      }
    </div>
    {cta && <div class="center"><CtaButton href={cta.href} label={cta.label} style="navy" /></div>}
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  .story {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-page);
    box-shadow: var(--shadow-sm);
    color: var(--text-strong);
    text-decoration: none;
    transition: transform 0.16s ease, box-shadow 0.16s ease;
  }
  .story:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  @media (prefers-reduced-motion: reduce) {
    .story:hover {
      transform: none;
    }
  }
  .cover {
    position: relative;
    aspect-ratio: 16 / 10;
    background-size: cover;
    background-position: center;
  }
  .location {
    position: absolute;
    left: 10px;
    bottom: 10px;
    padding: 3px 9px;
    border-radius: 5px;
    background: rgba(12, 19, 29, 0.7);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .body {
    padding: 15px 17px 17px;
  }
  .body h3 {
    font-size: 1rem;
    line-height: 1.3;
  }
  .more {
    display: inline-block;
    margin-top: 8px;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 800;
  }
  .center {
    margin-top: 40px;
    text-align: center;
  }
  @media (max-width: 1000px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
