---
import type { Block } from "../../schemas/blocks";
import SectionHeader from "../ui/SectionHeader.astro";
import CtaButton from "../ui/CtaButton.astro";

const { eyebrow, heading, intro, stories, cta } = Astro.props as Extract<
  Block,
  { type: "impactStories" }
>;
const [feature, ...rest] = stories;
---

<section class="block">
  <div class="shell">
    <SectionHeader eyebrow={eyebrow} heading={heading} intro={intro} align="left" />
    <div class="layout">
      <a class="feature" href={feature.href}>
        <div class="cover" style={`background-image:url(${feature.image})`}>
          <span class="location">{feature.location}</span>
        </div>
        <h3>{feature.title}</h3>
        <span class="more">Read the story</span>
      </a>
      <ul class="list">
        {
          rest.map((story) => (
            <li>
              <a href={story.href}>
                <span class="thumb" style={`background-image:url(${story.image})`} />
                <span class="body">
                  <span class="place">{story.location}</span>
                  <span class="title">{story.title}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    {cta && <div class="cta-row"><CtaButton href={cta.href} label={cta.label} style="navy" /></div>}
  </div>
</section>

<style>
  .layout {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: start;
  }
  .feature {
    display: block;
    text-decoration: none;
    color: var(--text-strong);
  }
  .feature .cover {
    aspect-ratio: 16 / 10;
    border-radius: var(--radius);
    background-size: cover;
    background-position: center;
    position: relative;
    box-shadow: var(--shadow-md);
  }
  .location,
  .place {
    color: var(--accent-text);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .feature .location {
    position: absolute;
    left: 12px;
    bottom: 12px;
    padding: 4px 10px;
    border-radius: 5px;
    background: rgba(12, 19, 29, 0.72);
    color: #fff;
  }
  .feature h3 {
    margin: 16px 0 6px;
    font-size: clamp(1.3rem, 2.4vw, 1.8rem);
    line-height: 1.15;
  }
  .feature .more {
    color: var(--accent-text);
    font-size: 0.85rem;
    font-weight: 800;
  }
  .feature .more::after {
    content: " →";
  }
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .list li {
    border-top: 1px solid var(--border);
  }
  .list li:last-child {
    border-bottom: 1px solid var(--border);
  }
  .list a {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 16px;
    align-items: center;
    padding: 16px 0;
    text-decoration: none;
    color: var(--text-strong);
  }
  .thumb {
    aspect-ratio: 1;
    border-radius: 10px;
    background-size: cover;
    background-position: center;
  }
  .list .title {
    display: block;
    margin-top: 4px;
    font-family: "Raleway", sans-serif;
    font-weight: 700;
    font-size: 0.98rem;
    line-height: 1.25;
  }
  .list a:hover .title {
    color: var(--accent-text);
  }
  .cta-row {
    margin-top: 36px;
  }
  @media (max-width: 820px) {
    .layout {
      grid-template-columns: 1fr;
    }
  }
</style>
