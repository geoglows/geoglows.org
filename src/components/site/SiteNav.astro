---
import type { z } from "astro:content";
import type { navItemSchema, linkSchema } from "../../schemas/shared";

type NavItem = z.infer<typeof navItemSchema>;
type Link = z.infer<typeof linkSchema>;

interface Props {
  nav: NavItem[];
  cta: Link;
}
const { nav, cta } = Astro.props;
---

<nav class="site-nav" aria-label="Main">
  <div class="shell nav-inner">
    <a href="/" class="brand" aria-label="GEOGLOWS home">
      <img class="logo logo-light" src="/images/geoglows-logo.webp" alt="GEOGLOWS" width="199" height="38" />
      <img class="logo logo-dark" src="/images/geoglows-logo-white.webp" alt="GEOGLOWS" width="184" height="38" />
    </a>
    <div class="nav-right">
      <button
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="site-menu"
        aria-label="Open menu"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M3 6h16M3 11h16M3 16h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
      <div class="links" id="site-menu">
        {
          nav.map((item) =>
            item.children?.length ? (
              <div class="group" data-open="false">
                <a class="group-label" href={item.href}>
                  {item.label}
                  <svg class="caret" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                    <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
                <button class="group-toggle" aria-expanded="false" aria-label={`Toggle ${item.label} menu`}>
                  <svg width="14" height="14" viewBox="0 0 12 12" aria-hidden="true">
                    <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </button>
                <div class="submenu">
                  {item.children.map((child) => <a href={child.href}>{child.label}</a>)}
                </div>
              </div>
            ) : (
              <a href={item.href}>{item.label}</a>
            ),
          )
        }
      </div>
      <a class="cta" href={cta.href}>{cta.label}</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector(".site-nav");
  const toggle = nav?.querySelector<HTMLButtonElement>(".nav-toggle");
  toggle?.addEventListener("click", () => {
    const open = nav?.getAttribute("data-open") === "true";
    nav?.setAttribute("data-open", String(!open));
    toggle.setAttribute("aria-expanded", String(!open));
    toggle.setAttribute("aria-label", open ? "Open menu" : "Close menu");
  });

  nav?.querySelectorAll<HTMLButtonElement>(".group-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const group = btn.closest(".group");
      const open = group?.getAttribute("data-open") === "true";
      group?.setAttribute("data-open", String(!open));
      btn.setAttribute("aria-expanded", String(!open));
    });
  });
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 60;
    background: color-mix(in srgb, var(--surface-page) 88%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-block: 12px;
  }
  .brand {
    display: inline-flex;
  }
  .logo {
    height: 38px;
  }
  .logo-dark {
    display: none;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 22px;
    margin-left: auto;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .links > a,
  .group-label {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--text-strong);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
  }
  .links > a:hover,
  .group-label:hover {
    color: var(--accent-text);
  }

  .group {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .group-toggle {
    display: none;
  }
  .caret {
    transition: transform 0.18s ease;
  }
  .group:hover .caret,
  .group:focus-within .caret {
    transform: rotate(-180deg);
    color: var(--accent-text);
  }
  .submenu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    display: none;
    flex-direction: column;
    padding: 7px;
    background: var(--surface-page);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-md);
  }
  .group:hover .submenu,
  .group:focus-within .submenu {
    display: flex;
  }
  .submenu a {
    padding: 9px 12px;
    border-radius: 7px;
    color: var(--text-body);
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .submenu a:hover {
    background: var(--surface-wash);
    color: var(--accent-text);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 8px;
    background: var(--color-green);
    color: #fff !important;
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface-page);
    color: var(--text-strong);
    cursor: pointer;
    transition: border-color 0.16s ease, color 0.16s ease;
  }
  .nav-toggle:hover {
    border-color: var(--accent-text);
    color: var(--accent-text);
  }

  @media (max-width: 880px) {
    .nav-toggle {
      display: inline-flex;
      order: 2;
    }
    .cta {
      order: 1;
    }
    .links {
      order: 3;
      position: absolute;
      inset: 100% 0 auto;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px var(--gutter) 16px;
      background: var(--surface-page);
      border-bottom: 1px solid var(--border);
      box-shadow: var(--shadow-md);
      display: none;
    }
    .site-nav[data-open="true"] .links {
      display: flex;
    }
    .links > a {
      min-height: 48px;
      border-bottom: 1px solid var(--border);
    }
    .group {
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
    }
    .group-label {
      flex: 1;
      min-height: 48px;
    }
    .caret {
      display: none;
    }
    .group-toggle {
      display: inline-flex;
      width: 48px;
      height: 48px;
      align-items: center;
      justify-content: center;
      border: none;
      background: none;
      color: var(--text-strong);
      cursor: pointer;
    }
    .group-toggle svg {
      transition: transform 0.18s ease;
    }
    .group[data-open="true"] .group-toggle svg {
      transform: rotate(-180deg);
    }
    .submenu {
      position: static;
      flex-basis: 100%;
      width: 100%;
      display: none;
      padding: 0 0 10px 12px;
      border: none;
      border-radius: 0;
      box-shadow: none;
      background: none;
    }
    .group[data-open="true"] .submenu {
      display: flex;
    }
    .group:hover .submenu,
    .group:focus-within .submenu {
      display: none;
    }
    .group[data-open="true"]:hover .submenu,
    .group[data-open="true"]:focus-within .submenu {
      display: flex;
    }
    .submenu a {
      min-height: 44px;
      display: flex;
      align-items: center;
    }
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .logo-light {
      display: none;
    }
    :root:not([data-theme="light"]) .logo-dark {
      display: block;
    }
  }
  :global(:root[data-theme="dark"]) .logo-light {
    display: none;
  }
  :global(:root[data-theme="dark"]) .logo-dark {
    display: block;
  }
</style>
