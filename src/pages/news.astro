---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import NewsCard from "../components/cards/NewsCard.astro";

const entries = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout
  title="News & Events | GEOGLOWS"
  description="Releases, training, and impact stories from the GEOGLOWS community."
>
  <section class="block">
    <div class="shell">
      <SectionHeader
        eyebrow="News & events"
        heading="Latest from the community"
        align="left"
        level={1}
      />
      <div class="grid">
        {entries.map((entry) => <NewsCard {...entry.data} />)}
      </div>
      <p class="more-link"><a href="/videos">Watch our videos →</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
  .more-link {
    margin-top: 32px;
  }
  .more-link a {
    color: var(--accent-text);
    font-weight: 700;
    text-decoration: none;
  }
</style>

