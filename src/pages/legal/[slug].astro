---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const docs = await getCollection("legal");
  return docs.map((doc) => ({ params: { slug: doc.id }, props: { doc } }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---

<BaseLayout title={`${doc.data.title} | GEOGLOWS`} description={doc.data.description}>
  <section class="block">
    <div class="legal">
      <p class="eyebrow">Legal</p>
      <h1>{doc.data.title}</h1>
      <p class="updated">Last updated: {doc.data.updated}</p>
      <div class="prose">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal {
    width: min(100% - var(--gutter) * 2, 760px);
    margin-inline: auto;
  }
  .eyebrow {
    color: var(--accent-text);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  h1 {
    margin-top: 8px;
    font-size: clamp(2rem, 4vw, 2.75rem);
  }
  .updated {
    margin-top: 10px;
    color: var(--text-faint);
    font-size: 0.9rem;
  }
  .prose {
    margin-top: 36px;
    color: var(--text-body);
    font-size: 1rem;
    line-height: 1.7;
  }
  .prose :global(h2) {
    margin-top: 40px;
    margin-bottom: 10px;
    color: var(--text-strong);
    font-size: 1.35rem;
  }
  .prose :global(h3) {
    margin-top: 26px;
    margin-bottom: 8px;
    color: var(--text-strong);
    font-size: 1.08rem;
  }
  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 16px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 22px;
  }
  .prose :global(li) {
    margin-bottom: 7px;
  }
  .prose :global(a) {
    color: var(--accent-text);
    font-weight: 600;
  }
  .prose :global(strong) {
    color: var(--text-strong);
  }
</style>
