{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/apps", "destination": "https://apps.geoglows.org" },
    { "source": "/apps/", "destination": "https://apps.geoglows.org" },
    { "source": "/apps/:path*", "destination": "https://apps.geoglows.org/:path*" }
  ]
}
